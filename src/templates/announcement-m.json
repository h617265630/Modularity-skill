          },
          {
            "name": "read_at",
            "type": "datetime",
            "nullable": false,
            "default": "now()"
          }
        ],
        "indexes": [
          {
            "name": "idx_announcement_reads_user_announcement",
            "columns": ["user_id", "announcement_id"],
            "unique": true
          }
        ]
      }
    ],
    "migrations": [
      {
        "name": "create_announcements_table",
        "sql": "CREATE TABLE IF NOT EXISTS announcements (...)"
      },
      {
        "name": "create_announcement_reads_table",
        "sql": "CREATE TABLE IF NOT EXISTS announcement_reads (...)"
      }
    ]
  },

  "integration": {
    "steps": [
      "1. Run database migration to create tables",
      "2. Add backend models in backend/app/db/models/announcement.py",
      "3. Add CRUD operations in backend/app/cruds/announcement_crud.py",
      "4. Register API routes in backend/app/api/router.py",
      "5. Create frontend components in frontend/src/components/announcements/",
      "6. Add API service in frontend/src/services/announcements.ts",
      "7. Integrate AnnouncementBanner into app layout",
      "8. Test announcement creation and display"
    ],
    "config_needed": [
      "Configure announcement types and their display styles",
      "Set up role-based access for announcement creation",
      "Configure default announcement duration"
    ]
  }
}
