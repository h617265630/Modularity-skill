{
  "command": "/category-tag-m",
  "feature_name": "category_tag_system",
  "description": "Content categorization with categories and tags support",

  "backend": {
    "routes": [
      {
        "method": "POST",
        "path": "/categories",
        "handler_name": "create_category",
        "auth_required": true
      },
      {
        "method": "GET",
        "path": "/categories",
        "handler_name": "get_categories",
        "auth_required": false
      },
      {
        "method": "PATCH",
        "path": "/categories/{id}",
        "handler_name": "update_category",
        "auth_required": true
      },
      {
        "method": "DELETE",
        "path": "/categories/{id}",
        "handler_name": "delete_category",
        "auth_required": true
      },
      {
        "method": "POST",
        "path": "/tags",
        "handler_name": "create_tag",
        "auth_required": false
      },
      {
        "method": "GET",
        "path": "/tags",
        "handler_name": "get_tags",
        "auth_required": false
      },
      {
        "method": "GET",
        "path": "/tags/{slug}",
        "handler_name": "get_tag_by_slug",
        "auth_required": false
      },
      {
        "method": "DELETE",
        "path": "/tags/{id}",
        "handler_name": "delete_tag",
        "auth_required": true
      }
    ],
    "services": [
      {
        "name": "CategoryService",
        "description": "Business logic for categories",
        "methods": [
          {
            "name": "create_category",
            "description": "Create new category",
            "async": true
          },
          {
            "name": "get_category_tree",
            "description": "Get hierarchical category tree",
            "async": true
          },
          {
            "name": "get_posts_by_category",
            "description": "Get posts in a category including subcategories",
            "async": true
          }
        ]
      },
      {
        "name": "TagService",
        "description": "Business logic for tags",
        "methods": [
          {
            "name": "create_or_get_tag",
            "description": "Create new tag or return existing",
            "async": true
          },
          {
            "name": "get_popular_tags",
            "description": "Get most used tags",
            "async": true
          },
          {
            "name": "get_posts_by_tag",
            "description": "Get posts with a specific tag",
            "async": true
          }
        ]
      }
    ],
    "models": [
      {
        "name": "Category",
        "table_name": "categories",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false,
            "index": true
          },
          {
            "name": "name",
            "type": "string",
            "nullable": false
          },
          {
            "name": "slug",
            "type": "string",
            "nullable": false,
            "index": true
          },
          {
            "name": "parent_id",
            "type": "integer",
            "nullable": true,
            "foreign_key": "categories.id",
            "index": true
          },
          {
            "name": "description",
            "type": "string",
            "nullable": true
          },
          {
            "name": "icon",
            "type": "string",
            "nullable": true
          },
          {
            "name": "post_count",
            "type": "integer",
            "nullable": false,
            "default": "0"
          },
          {
            "name": "sort_order",
            "type": "integer",
            "nullable": false,
            "default": "0"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "datetime.utcnow()"
          }
        ],
        "indexes": [
          {
            "name": "idx_categories_slug",
            "columns": ["slug"],
            "unique": true
          },
          {
            "name": "idx_categories_parent",
            "columns": ["parent_id"]
          }
        ]
      },
      {
        "name": "Tag",
        "table_name": "tags",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false,
            "index": true
          },
          {
            "name": "name",
            "type": "string",
            "nullable": false
          },
          {
            "name": "slug",
            "type": "string",
            "nullable": false,
            "index": true
          },
          {
            "name": "post_count",
            "type": "integer",
            "nullable": false,
            "default": "0"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "datetime.utcnow()"
          }
        ],
        "indexes": [
          {
            "name": "idx_tags_slug",
            "columns": ["slug"],
            "unique": true
          },
          {
            "name": "idx_tags_name",
            "columns": ["name"]
          }
        ]
      },
      {
        "name": "ContentTag",
        "table_name": "content_tags",
        "description": "Polymorphic tag association - supports any content type",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false,
            "index": true
          },
          {
            "name": "content_type",
            "type": "string",
            "nullable": false,
            "description": "Content type: 'post', 'video', 'product', etc."
          },
          {
            "name": "content_id",
            "type": "integer",
            "nullable": false,
            "description": "ID of the content item"
          },
          {
            "name": "tag_id",
            "type": "integer",
            "nullable": false,
            "foreign_key": "tags.id",
            "index": true
          },
          {
            "name": "created_by",
            "type": "integer",
            "nullable": true,
            "foreign_key": "users.id"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "datetime.utcnow()"
          }
        ],
        "indexes": [
          {
            "name": "idx_content_tags_content",
            "columns": ["content_type", "content_id"]
          },
          {
            "name": "idx_content_tags_tag",
            "columns": ["tag_id"]
          },
          {
            "name": "idx_content_tags_unique",
            "columns": ["content_type", "content_id", "tag_id"],
            "unique": true
          }
        ]
      }
    ],
    "curds": [
      {
        "name": "category_crud",
        "model_name": "Category",
        "operations": ["create", "read", "update", "delete"]
      },
      {
        "name": "tag_crud",
        "model_name": "Tag",
        "operations": ["create", "read", "delete"]
      },
      {
        "name": "content_tag_crud",
        "model_name": "ContentTag",
        "operations": ["create", "read", "delete"]
      }
    ]
  },

  "frontend": {
    "components": [
      {
        "name": "CategorySelect",
        "description": "Dropdown select for category with tree support",
        "props": [
          {
            "name": "value",
            "type": "number",
            "required": false
          },
          {
            "name": "onChange",
            "type": "(categoryId: number) => void",
            "required": true
          },
          {
            "name": "allowClear",
            "type": "boolean",
            "required": false
          }
        ]
      },
      {
        "name": "TagInput",
        "description": "Tag input component with autocomplete",
        "props": [
          {
            "name": "value",
            "type": "Tag[]",
            "required": true
          },
          {
            "name": "onChange",
            "type": "(tags: Tag[]) => void",
            "required": true
          },
          {
            "name": "suggestions",
            "type": "Tag[]",
            "required": false
          },
          {
            "name": "maxTags",
            "type": "number",
            "required": false
          }
        ]
      }
    ],
    "hooks": [
      {
        "name": "useCategories",
        "description": "Fetch all categories",
        "returns": "{ categories: Category[]; loading: boolean }"
      },
      {
        "name": "useTags",
        "description": "Fetch all tags or search tags",
        "returns": "{ tags: Tag[]; search: (query: string) => void; loading: boolean }"
      },
      {
        "name": "usePopularTags",
        "description": "Fetch popular tags",
        "returns": "{ tags: Tag[]; loading: boolean }"
      }
    ],
    "pages": []
  },

  "database": {
    "tables": [
      {
        "name": "categories",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false
          },
          {
            "name": "name",
            "type": "string",
            "nullable": false
          },
          {
            "name": "slug",
            "type": "string",
            "nullable": false
          },
          {
            "name": "parent_id",
            "type": "integer",
            "nullable": true,
            "foreign_key": "categories.id"
          },
          {
            "name": "description",
            "type": "string",
            "nullable": true
          },
          {
            "name": "icon",
            "type": "string",
            "nullable": true
          },
          {
            "name": "post_count",
            "type": "integer",
            "nullable": false,
            "default": "0"
          },
          {
            "name": "sort_order",
            "type": "integer",
            "nullable": false,
            "default": "0"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "now()"
          }
        ],
        "indexes": [
          {
            "name": "idx_categories_slug",
            "columns": ["slug"],
            "unique": true
          },
          {
            "name": "idx_categories_parent",
            "columns": ["parent_id"]
          }
        ]
      },
      {
        "name": "tags",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false
          },
          {
            "name": "name",
            "type": "string",
            "nullable": false
          },
          {
            "name": "slug",
            "type": "string",
            "nullable": false
          },
          {
            "name": "use_count",
            "type": "integer",
            "nullable": false,
            "default": "0",
            "description": "Cached count of all content associations"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "now()"
          }
        ],
        "indexes": [
          {
            "name": "idx_tags_slug",
            "columns": ["slug"],
            "unique": true
          },
          {
            "name": "idx_tags_name",
            "columns": ["name"]
          }
        ]
      },
      {
        "name": "content_tags",
        "description": "Polymorphic tag association - supports any content type",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false
          },
          {
            "name": "content_type",
            "type": "string",
            "nullable": false,
            "description": "Content type: 'post', 'video', 'product', etc."
          },
          {
            "name": "content_id",
            "type": "integer",
            "nullable": false,
            "description": "ID of the content item"
          },
          {
            "name": "tag_id",
            "type": "integer",
            "nullable": false,
            "foreign_key": "tags.id"
          },
          {
            "name": "created_by",
            "type": "integer",
            "nullable": true,
            "foreign_key": "users.id"
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "now()"
          }
        ],
        "indexes": [
          {
            "name": "idx_content_tags_content",
            "columns": ["content_type", "content_id"]
          },
          {
            "name": "idx_content_tags_tag",
            "columns": ["tag_id"]
          },
          {
            "name": "idx_content_tags_unique",
            "columns": ["content_type", "content_id", "tag_id"],
            "unique": true
          }
        ]
      }
    ],
    "migrations": [
      {
        "name": "create_categories_table",
        "sql": "CREATE TABLE IF NOT EXISTS categories (...)"
      },
      {
        "name": "create_tags_table",
        "sql": "CREATE TABLE IF NOT EXISTS tags (...)"
      },
      {
        "name": "create_content_tags_table",
        "sql": "CREATE TABLE IF NOT EXISTS content_tags (...)"
      }
    ]
  },

  "integration": {
    "steps": [
      "1. Run database migration to create tables",
      "2. Add backend models in backend/app/db/models/category_tag.py",
      "3. Add CRUD operations in backend/app/cruds/",
      "4. Register API routes in backend/app/api/router.py",
      "5. Create frontend components in frontend/src/components/category-tag/",
      "6. Add API service in frontend/src/services/category-tag.ts",
      "7. Integrate CategorySelect and TagInput into PostEditor"
    ],
    "config_needed": [
      "Set up slug generation for categories and tags",
      "Configure post_count increment/decrement triggers"
    ]
  }
}
