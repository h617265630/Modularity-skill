{
  "command": "/password-m",
  "feature_name": "password_system",
  "description": "Password management system with change and reset functionality",

  "backend": {
    "routes": [
      {
        "method": "POST",
        "path": "/auth/change-password",
        "handler_name": "change_password",
        "auth_required": true
      },
      {
        "method": "POST",
        "path": "/auth/forgot-password",
        "handler_name": "forgot_password",
        "auth_required": false
      },
      {
        "method": "POST",
        "path": "/auth/reset-password",
        "handler_name": "reset_password",
        "auth_required": false
      },
      {
        "method": "POST",
        "path": "/auth/verify-reset-token",
        "handler_name": "verify_reset_token",
        "auth_required": false
      }
    ],
    "services": [
      {
        "name": "PasswordService",
        "description": "Business logic for password operations",
        "methods": [
          {
            "name": "change_password",
            "description": "Change user password with old password verification",
            "async": true
          },
          {
            "name": "request_password_reset",
            "description": "Generate password reset token and send email",
            "async": true
          },
          {
            "name": "reset_password_with_token",
            "description": "Reset password using token",
            "async": true
          },
          {
            "name": "validate_password_strength",
            "description": "Validate password meets security requirements",
            "async": false
          }
        ]
      }
    ],
    "models": [
      {
        "name": "PasswordResetToken",
        "table_name": "password_reset_tokens",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false,
            "index": true
          },
          {
            "name": "user_id",
            "type": "integer",
            "nullable": false,
            "foreign_key": "users.id",
            "index": true
          },
          {
            "name": "token",
            "type": "string",
            "nullable": false,
            "index": true
          },
          {
            "name": "token_type",
            "type": "string",
            "nullable": false,
            "default": "'reset'"
          },
          {
            "name": "expires_at",
            "type": "datetime",
            "nullable": false
          },
          {
            "name": "used_at",
            "type": "datetime",
            "nullable": true
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "datetime.utcnow()"
          }
        ],
        "indexes": [
          {
            "name": "idx_password_reset_token",
            "columns": ["token"],
            "unique": true
          },
          {
            "name": "idx_password_reset_user",
            "columns": ["user_id"]
          }
        ]
      }
    ],
    "curds": [
      {
        "name": "password_reset_token_crud",
        "model_name": "PasswordResetToken",
        "operations": ["create", "read", "update"]
      }
    ]
  },

  "frontend": {
    "components": [
      {
        "name": "ChangePasswordForm",
        "description": "Form to change password with old password verification",
        "props": [
          {
            "name": "onSuccess",
            "type": "() => void",
            "required": true
          },
          {
            "name": "onCancel",
            "type": "() => void",
            "required": false
          }
        ]
      },
      {
        "name": "ForgotPasswordForm",
        "description": "Form to request password reset email",
        "props": [
          {
            "name": "onSuccess",
            "type": "() => void",
            "required": true
          }
        ]
      },
      {
        "name": "ResetPasswordForm",
        "description": "Form to reset password with token",
        "props": [
          {
            "name": "token",
            "type": "string",
            "required": true
          },
          {
            "name": "onSuccess",
            "type": "() => void",
            "required": true
          }
        ]
      },
      {
        "name": "PasswordStrengthIndicator",
        "description": "Visual indicator of password strength",
        "props": [
          {
            "name": "password",
            "type": "string",
            "required": true
          }
        ]
      }
    ],
    "hooks": [
      {
        "name": "useChangePassword",
        "description": "Change user password",
        "returns": "{ change: (oldPassword: string, newPassword: string) => Promise<void>; isLoading: boolean; error: string | null }"
      },
      {
        "name": "useForgotPassword",
        "description": "Request password reset",
        "returns": "{ request: (email: string) => Promise<void>; isLoading: boolean; success: boolean }"
      },
      {
        "name": "useResetPassword",
        "description": "Reset password with token",
        "returns": "{ reset: (token: string, newPassword: string) => Promise<void>; isLoading: boolean; error: string | null }"
      }
    ],
    "pages": [
      {
        "name": "ForgotPasswordPage",
        "route": "/forgot-password",
        "description": "Request password reset page"
      },
      {
        "name": "ResetPasswordPage",
        "route": "/reset-password",
        "description": "Reset password page with token"
      },
      {
        "name": "ChangePasswordPage",
        "route": "/settings/password",
        "description": "Change password page"
      }
    ]
  },

  "database": {
    "tables": [
      {
        "name": "password_reset_tokens",
        "fields": [
          {
            "name": "id",
            "type": "integer",
            "nullable": false
          },
          {
            "name": "user_id",
            "type": "integer",
            "nullable": false,
            "foreign_key": "users.id"
          },
          {
            "name": "token",
            "type": "string",
            "nullable": false
          },
          {
            "name": "token_type",
            "type": "string",
            "nullable": false,
            "default": "'reset'"
          },
          {
            "name": "expires_at",
            "type": "datetime",
            "nullable": false
          },
          {
            "name": "used_at",
            "type": "datetime",
            "nullable": true
          },
          {
            "name": "created_at",
            "type": "datetime",
            "nullable": false,
            "default": "now()"
          }
        ],
        "indexes": [
          {
            "name": "idx_password_reset_token",
            "columns": ["token"],
            "unique": true
          },
          {
            "name": "idx_password_reset_user",
            "columns": ["user_id"]
          }
        ]
      }
    ],
    "migrations": [
      {
        "name": "create_password_reset_tokens_table",
        "sql": "CREATE TABLE IF NOT EXISTS password_reset_tokens (...)"
      }
    ]
  },

  "integration": {
    "steps": [
      "1. Run database migration to create 'password_reset_tokens' table",
      "2. Add backend models in backend/app/db/models/password.py",
      "3. Add CRUD operations in backend/app/cruds/password_crud.py",
      "4. Register API routes in backend/app/api/router.py",
      "5. Configure email service for password reset emails",
      "6. Create frontend components in frontend/src/components/password/",
      "7. Add API service in frontend/src/services/password.ts",
      "8. Integrate into settings page",
      "9. Test password change and reset flow"
    ],
    "config_needed": [
      "Set up email service for password reset emails",
      "Configure password reset token expiry (default: 1 hour)",
      "Configure password minimum requirements (length, complexity)"
    ]
  }
}
